# Shrap Firm - infra .env (example).
#
# Copy this file to .env in the same directory and fill in real values.
# The real .env is git-ignored (see /.gitignore). Never commit secrets.
#
# Generate strong values for secrets with:
#   openssl rand -base64 48     # for NEXTAUTH_SECRET and SALT
#   openssl rand -base64 24     # for passwords

# ----------------------------------------------------------------------------
# Primary Postgres (TimescaleDB) - owns all firm-internal schemas.
# ----------------------------------------------------------------------------

# Database superuser name for the firm's Postgres instance.
SHRAP_DB_USER=shrap

# Database superuser password. Replace with a strong generated value.
SHRAP_DB_PASSWORD=change-me-strong-random-value

# Initial database created at first boot. Agents connect here by default.
SHRAP_DB_NAME=shrap

# ----------------------------------------------------------------------------
# Langfuse dedicated Postgres - isolated so Langfuse migrations don't
# collide with the firm's main schema.
# ----------------------------------------------------------------------------

# Superuser for the Langfuse-only Postgres container.
LANGFUSE_DB_USER=langfuse

# Password for the Langfuse Postgres container.
LANGFUSE_DB_PASSWORD=change-me-strong-random-value

# ----------------------------------------------------------------------------
# Langfuse app - NextAuth session crypto + canonical public URL.
# ----------------------------------------------------------------------------

# NextAuth session signing secret. Must be at least 32 bytes of entropy.
NEXTAUTH_SECRET=change-me-openssl-rand-base64-48

# Canonical URL Langfuse is reached at. For local-only Dell deployment,
# leave as the loopback URL; tunnel via SSH from the MacBook to access.
NEXTAUTH_URL=http://localhost:3000

# Application-wide salt for Langfuse hashing of API keys etc.
SALT=change-me-openssl-rand-base64-48

# ----------------------------------------------------------------------------
# Grafana - initial admin password. Change after first login if desired.
# ----------------------------------------------------------------------------

GF_SECURITY_ADMIN_PASSWORD=change-me-strong-random-value

# ----------------------------------------------------------------------------
# Health Monitor (first agent). See docs/agents/operations/health-monitor.md.
# ----------------------------------------------------------------------------

# Discord webhook for routine alerts (degraded / recovered). Leave blank to
# disable Discord routing — alerts will then only go to ntfy.sh (if set).
HEALTH_MONITOR_DISCORD_WEBHOOK_URL=

# ntfy.sh topic URL for urgent (system-wide) alerts. Example for a local
# ntfy container: http://ntfy:8080/shrap-urgent
HEALTH_MONITOR_NTFY_URL=

# Tick cadence in seconds. 30 is the documented default.
HEALTH_MONITOR_TICK_INTERVAL_SECONDS=30

# Consecutive bad ticks before declaring a check degraded. Avoids flaps.
HEALTH_MONITOR_DEGRADATION_THRESHOLD_CONSECUTIVE_TICKS=2

# Consecutive good ticks before declaring a check recovered.
HEALTH_MONITOR_RECOVERY_THRESHOLD_CONSECUTIVE_TICKS=3
